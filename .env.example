# Anthropic / Claude API
# קבל מפתח ב-https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# הגדרות כלליות (אופציונלי)
# מודל ברירת מחדל לסוכנים
DEFAULT_MODEL=claude-opus-4-8

# OpenAI Images API
# קבל מפתח ב-https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
